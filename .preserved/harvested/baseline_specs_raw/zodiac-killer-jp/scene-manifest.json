  "topic": "ゾディアック事件",
  "topic_en": "Zodiac Killer",
  "language": "ja",
  "total_clips": 15,
  "clips": [
    {
      "index": 0,
      "section_index": 0,
      "section_type": "hook",
      "speaker_id": "narrator",
      "narration_sentence": "[インロト シグネチャー]",
      "start_ms": 0,
      "duration_s": 3,
      "source": {
        "type": "signature",
        "local_path": "sources/intro_signature.mp4",
        "provider": "veo_reuse",
        "volume": 0,
        "description": "イントロ シグネチャー - 探偵シルエット"
      }
    },
    {
      "index": 1,
      "section_index": 0,
      "section_type": "hook",
      "speaker_id": "narrator",
      "narration_sentence": "千九百六十九年、カリフォルニア。ひとりの殺人鬼が現れた。名乗ったのは、ゾディアック。",
      "start_ms": 3000,
      "duration_s": 7,
      "source": {
        "type": "image",
        "local_path": "sources/zodiac_wanted_poster.jpg",
        "provider": "serper",
        "description": "ゾディアック・キラー 警察モンタージュ手配書 - 1960年代の捜査開始"
      }
    },
    {
      "index": 2,
      "section_index": 0,
      "section_type": "hook",
      "speaker_id": "narrator",
      "narration_sentence": "五人を殺し、新聞社に暗号を送りつけ、警察を嘲り続けた。今日の記録だ。",
      "start_ms": 10000,
      "duration_s": 4,
      "source": {
        "type": "image",
        "local_path": "sources/zodiac_cipher_letter.jpg",
        "provider": "serper",
        "description": "ゾディアックが新聞社に送った直筆の手紙原本"
      }
    },
    {
      "index": 3,
      "section_index": 1,
      "section_type": "body",
      "speaker_id": "narrator",
      "narration_sentence": "最初の犯行は千九百六十八年十二月。ベニシアの湖畔の道で、十七歳と十六歳のカップルが撃たれた。",
      "start_ms": 15250,
      "duration_s": 8,
      "source": {
        "type": "image",
        "local_path": "sources/z340_cipher_original.jpg",
        "provider": "serper",
        "description": "Z340暗号文 原本 - ゾディアック事件を象徴する暗号"
      }
    },
    {
      "index": 4,
      "section_index": 1,
      "section_type": "body",
      "speaker_id": "narrator",
      "narration_sentence": "翌年七月にはヴァレーホの駐車場でも若い男女が襲われている。だが犯人はそのあと、自ら警察に電話をかけ、「俺がやった」と告げた。",
      "start_ms": 23250,
      "duration_s": 12,
      "source": {
        "type": "image",
        "local_path": "sources/z340_cipher_news.jpg",
        "provider": "serper",
        "description": "Z340暗号文関連のニュース報道画面 - 新聞社に送られた暗号"
      }
    },
    {
      "index": 5,
      "section_index": 2,
      "section_type": "body",
      "speaker_id": "assistant",
      "narration_sentence": "自分から名乗り出た... なぜそんなことをするんですか？",
      "start_ms": 35880,
      "duration_s": 4,
      "source": {
        "type": "image",
        "local_path": "sources/zodiac_stine_shirt_letter.jpg",
        "provider": "serper",
        "description": "ゾディアックがポール・スタインの血のついたシャツの切れ端と共に送った手紙"
      }
    },
    {
      "index": 6,
      "section_index": 3,
      "section_type": "body",
      "speaker_id": "narrator",
      "narration_sentence": "見せつけたかったんだろう。九月にはさらに手口が変わった。レイク・ベリエッサで大学生のカップルを縛り上げ、ナイフで何度も刺している。犯人は、十字の印が描かれた黒い覆面をかぶっていた。",
      "start_ms": 40262,
      "duration_s": 14,
      "source": {
        "type": "image",
        "local_path": "sources/lake_berryessa_car_door.jpg",
        "provider": "serper",
        "description": "Lake Berryessa 車のドアに刻まれた十字マークと日付"
      }
    },
    {
      "index": 7,
      "section_index": 4,
      "section_type": "body",
      "speaker_id": "narrator",
      "narration_sentence": "十月にはサンフランシスコの街中でタクシー運転手を射殺した。街灯の下、目撃者は三人。顔も見られている... だが、逮捕には至っていない。",
      "start_ms": 54544,
      "duration_s": 12,
      "source": {
        "type": "image",
        "local_path": "sources/paul_stine_crime_scene.jpg",
        "provider": "serper",
        "description": "タクシー運転手ポール・スタイン事件現場の写真"
      }
    },
    {
      "index": 8,
      "section_index": 5,
      "section_type": "body",
      "speaker_id": "narrator",
      "narration_sentence": "ゾディアックは四通の暗号文を新聞社に送った。最初の暗号を解いたのは教師の夫婦だった。",
      "start_ms": 66318,
      "duration_s": 7,
      "source": {
        "type": "image",
        "local_path": "sources/z13_cipher_hq.jpg",
        "provider": "serper",
        "description": "Z13暗号文 高解像度 - 未解読の13文字暗号"
      }
    },
    {
      "index": 9,
      "section_index": 5,
      "section_type": "body",
      "speaker_id": "narrator",
      "narration_sentence": "そこにはこう書かれていた。「人を殺すのは楽しい。森で獲物を狩るより、ずっと面白い」。",
      "start_ms": 73318,
      "duration_s": 7,
      "source": {
        "type": "image",
        "local_path": "sources/lake_berryessa_door_full.jpg",
        "provider": "serper",
        "description": "Lake Berryessa 車のドア全体 - 日付と十字マークが刻まれた全景"
      }
    },
    {
      "index": 10,
      "section_index": 6,
      "section_type": "body",
      "speaker_id": "assistant",
      "narration_sentence": "五十一年も解けなかった暗号がありますよね。あれには、何が書かれていたんですか？",
      "start_ms": 80600,
      "duration_s": 7,
      "source": {
        "type": "image",
        "local_path": "sources/z13_cipher.jpg",
        "provider": "serper",
        "description": "Z13暗号文の実物画像 - 13文字の暗号に自分の名前を入れたと主張"
      }
    },
    {
      "index": 11,
      "section_index": 7,
      "section_type": "body",
      "speaker_id": "narrator",
      "narration_sentence": "二千二十年に、三人のアマチュア研究者がようやく解読した。三百四十文字、六十三種類の記号。五十一年かけて出た答えは... 「俺を捕まえるの、楽しんでるか」。五十年越しの嘲笑だった。",
      "start_ms": 87855,
      "duration_s": 16,
      "source": {
        "type": "image",
        "local_path": "sources/z340_decoded_popsci.jpg",
        "provider": "serper",
        "description": "Z340暗号解読成功の記事 - 2020年アマチュアチームによる解読過程"
      }
    },
    {
      "index": 12,
      "section_index": 8,
      "section_type": "cta",
      "speaker_id": "narrator",
      "narration_sentence": "最有力の容疑者はDNA鑑定で否定されている。二千二十六年のいま、FBIが新たな人物を検討しているとも報じられた。だが犯人の名前は、いまだに分からない。残る暗号は二通。答えはまだ、その中に眠っているのかもしれない。",
      "start_ms": 104175,
      "duration_s": 19,
      "source": {
        "type": "image",
        "local_path": "sources/arthur_leigh_allen.jpg",
        "provider": "serper",
        "description": "最有力容疑者アーサー・リー・アレンの実際の写真"
      }
    },
    {
      "index": 13,
      "section_index": 9,
      "section_type": "cta",
      "speaker_id": "assistant",
      "narration_sentence": "まだ解かれていない暗号がある... 気になりませんか。チャンネル登録、お願いします。",
      "start_ms": 123238,
      "duration_s": 7,
      "source": {
        "type": "image",
        "local_path": "sources/paul_stine_scene.jpg",
        "provider": "serper",
        "description": "ポール・スタインのタクシー事件現場2 - 事件の余韻"
      }
    },
    {
      "index": 14,
      "section_index": 9,
      "section_type": "cta",
      "speaker_id": "narrator",
      "narration_sentence": "[アウトロ シグネチャー]",
      "start_ms": 130213,
