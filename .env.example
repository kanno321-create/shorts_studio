# shorts_studio — Environment Variables Template
# Copy this file to .env and fill in your API keys.
# 원본 레지스트리: C:/Users/PC/Desktop/shorts_naberal/.env (memory: reference_api_keys_location)
# Last synced:   2026-04-20 (세션 #26)

# =============================================================================
# TTS (Stage 3 — Typecast primary + ElevenLabs fallback)
# =============================================================================
# Primary (한국 채널 전부 + incidents-jp 는 VOICEVOX 로컬 서버)
TYPECAST_API_KEY=

# Fallback (영어 채널 primary / 한국 채널 fallback)
ELEVENLABS_API_KEY=
# Optional: 기본 voice_id override (voice_discovery 가 auto-resolve 실패 시 fallback)
ELEVENLABS_DEFAULT_VOICE_ID=

# =============================================================================
# Image (Stage 2 — Nano Banana Pro)
# =============================================================================
GOOGLE_API_KEY=

# =============================================================================
# Video (Stage 4 — Kling 2.6 Pro primary / Veo 3.1 Fast fallback)
# =============================================================================
# Via fal.ai (공용 key, 권장)
FAL_KEY=

# Kling 직접 호출 시 (fal.ai 우회)
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# Runway hold adapter (production path 미호출, 코드만 유지)
RUNWAY_API_KEY=

# =============================================================================
# YouTube (Phase 8 remote publishing)
# =============================================================================
# client_secret.json + youtube_token.json 은 config/ 에 별도 관리 (OAuth2)
# API key 직접 호출 불필요

# =============================================================================
# 금지 항목 (memory: project_claude_code_max_no_api_key)
# =============================================================================
# ANTHROPIC_API_KEY 는 등록 금지.
# Claude CLI subprocess (claude --print --append-system-prompt) 경로 사용.
# Max 구독 billing 으로 자동 처리.
